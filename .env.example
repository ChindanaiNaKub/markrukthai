# Server Configuration
PORT=3000
NODE_ENV=development

# Database
# Local SQLite fallback for development
DATA_DIR=./data

# Turso production database
# TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# Optional accounts and admin access
# AUTH_SECRET=generate_a_random_secret
# ADMIN_EMAILS=you@example.com,another-admin@example.com

# Passwordless email delivery (required in production if you want sign-in emails)
# RESEND_API_KEY=re_xxx
# AUTH_FROM_EMAIL=ThaiChess <noreply@yourdomain.com>
